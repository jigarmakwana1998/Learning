# Copy to .env, generate unique values, and keep the resulting file private.
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
NEO4J_PASSWORD=replace-with-a-long-random-neo4j-password
MINIO_ROOT_USER=learning-coach-minio
MINIO_ROOT_PASSWORD=replace-with-a-long-random-minio-password
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-long-random-grafana-password
# Local HTTP port. Use a domain-specific production Caddy configuration for TLS.
HTTP_PORT=8080
