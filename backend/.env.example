# Select the default agent runtime. Per-request selection is also supported.
AGENT_PROVIDER=mock
APP_NAME=Learning Coach API
APP_VERSION=0.4.0
ENVIRONMENT=development

# Persistent data and authentication. For Supabase, use its Session pooler
# connection string (with the asyncpg driver) and Project Connect credentials.
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-key>
JWT_SECRET=replace-with-a-random-32-plus-character-secret
APP_ENCRYPTION_KEY=q0_mL9PZ2Ik1Wl9qVzYmIDQDfL8dbbSbix-AJZAcBLk=
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-now

# Optional: override CLI invocation if your installed version uses different flags.
# The command must read the prompt on stdin and emit one JSON object on stdout.
# CODEX_COMMAND=codex exec --output-format json
# GEMINI_CLI_COMMAND=gemini --output-format json
# ANTIGRAVITY_CLI_COMMAND=agy --output-format json
