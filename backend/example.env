# Copy to backend/.env and replace every placeholder before deployment.
AGENT_PROVIDER=mock

# Supabase Postgres Session Pooler connection (SQLAlchemy async driver).
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-key>

# Application-level secrets and role configuration.
APP_ENCRYPTION_KEY=replace-with-a-generated-fernet-key
ADMIN_EMAIL=admin@example.com

# Only used by the SQLite/local-auth fallback, not by Supabase production auth.
JWT_SECRET=replace-with-a-random-32-plus-character-secret
ADMIN_PASSWORD=change-me-now

# Optional real-agent CLI command overrides.
# CODEX_COMMAND=codex exec --output-format json
# GEMINI_CLI_COMMAND=gemini --output-format json
# ANTIGRAVITY_CLI_COMMAND=agy --output-format json
